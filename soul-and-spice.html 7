<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Soul & Spice — Nigerian Kitchen</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --gold: #C8860A;
    --gold-light: #F5C842;
    --deep-red: #8B1A1A;
    --cream: #FDF6EC;
    --brown: #3E1F00;
    --orange: #E05C1A;
    --bg-dark: #1A0A00;
    --text-muted: #A08060;
    --success: #2e7d32;
  }

  html { scroll-behavior: smooth; }
  body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--brown); overflow-x: hidden; }

  /* ─── AUTH GATE ─── */
  #authGate {
    display: none;
    position: fixed;
    inset: 0;
    background: var(--bg-dark);
    z-index: 2000;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    overflow-y: auto;
  }
  #authGate.show { display: flex; }

  .auth-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.05;
    background-image: repeating-linear-gradient(45deg,#C8860A 0px,#C8860A 1px,transparent 1px,transparent 28px),
      repeating-linear-gradient(-45deg,#C8860A 0px,#C8860A 1px,transparent 1px,transparent 28px);
  }

  .auth-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(200,134,10,0.2) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 80% 100%, rgba(224,92,26,0.15) 0%, transparent 60%);
  }

  .auth-card {
    background: var(--cream);
    border-radius: 16px;
    padding: 2.5rem;
    max-width: 420px;
    width: 100%;
    position: relative;
    z-index: 1;
    animation: authSlideIn 0.4s cubic-bezier(0.34,1.56,0.64,1) both;
  }

  @keyframes authSlideIn {
    from { opacity: 0; transform: translateY(40px) scale(0.95); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .auth-logo {
    text-align: center;
    margin-bottom: 1.5rem;
  }
  .auth-logo-name {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 900;
    color: var(--brown);
    line-height: 1;
  }
  .auth-logo-name span { color: var(--gold); font-style: italic; }
  .auth-logo-tagline {
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-top: 0.3rem;
  }

  .auth-tabs {
    display: flex;
    background: rgba(200,134,10,0.08);
    border-radius: 8px;
    padding: 4px;
    margin-bottom: 1.8rem;
  }
  .auth-tab {
    flex: 1;
    padding: 0.6rem;
    text-align: center;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
    color: var(--text-muted);
    border: none;
    background: none;
  }
  .auth-tab.active {
    background: var(--gold);
    color: #fff;
    box-shadow: 0 2px 8px rgba(200,134,10,0.35);
  }

  .auth-panel { display: none; }
  .auth-panel.active { display: block; }

  .auth-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--brown);
    margin-bottom: 0.25rem;
  }
  .auth-sub {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .auth-field { margin-bottom: 1rem; }
  .auth-field label {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-weight: 500;
    margin-bottom: 0.35rem;
  }
  .auth-field input {
    width: 100%;
    padding: 0.8rem 1rem;
    border: 1.5px solid rgba(200,134,10,0.25);
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    color: var(--brown);
    background: #fff;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .auth-field input:focus {
    border-color: var(--gold);
    box-shadow: 0 0 0 3px rgba(200,134,10,0.12);
  }
  .auth-field input.error { border-color: var(--deep-red); }
  .auth-field .err-msg {
    font-size: 0.73rem;
    color: var(--deep-red);
    margin-top: 0.3rem;
    display: none;
  }
  .auth-field .err-msg.show { display: block; }

  .auth-btn {
    width: 100%;
    padding: 0.9rem;
    background: var(--gold);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    margin-top: 0.5rem;
  }
  .auth-btn:hover {
    background: #b07308;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(200,134,10,0.3);
  }
  .auth-btn:active { transform: translateY(0); }

  .auth-divider { height: 1px; background: rgba(200,134,10,0.15); margin: 1.5rem 0; }

  .auth-alert {
    padding: 0.75rem 1rem;
    border-radius: 6px;
    font-size: 0.83rem;
    margin-bottom: 1rem;
    display: none;
  }
  .auth-alert.error { background: #fff0f0; border: 1px solid rgba(139,26,26,0.25); color: var(--deep-red); display: block; }
  .auth-alert.success { background: #f0fff4; border: 1px solid rgba(46,125,50,0.25); color: var(--success); display: block; }

  /* ─── NAVBAR ─── */
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 500;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2rem;
    background: rgba(26,10,0,0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(200,134,10,0.2);
  }
  .nav-brand {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 900;
    color: var(--cream);
  }
  .nav-brand span { color: var(--gold-light); font-style: italic; }
  .nav-right { display: flex; align-items: center; gap: 0.75rem; }

  .nav-user-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(200,134,10,0.15);
    border: 1px solid rgba(200,134,10,0.3);
    border-radius: 50px;
    padding: 0.45rem 1rem 0.45rem 0.5rem;
    cursor: pointer;
    transition: background 0.2s;
    color: var(--cream);
    font-size: 0.82rem;
    font-family: 'DM Sans', sans-serif;
  }
  .nav-user-btn:hover { background: rgba(200,134,10,0.25); }
  .nav-avatar {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: var(--gold);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--bg-dark);
    flex-shrink: 0;
  }

  .nav-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 2rem;
    background: var(--cream);
    border-radius: 10px;
    box-shadow: 0 8px 32px rgba(26,10,0,0.25);
    border: 1px solid rgba(200,134,10,0.2);
    min-width: 200px;
    overflow: hidden;
    display: none;
    animation: dropDown 0.2s ease;
  }
  .nav-dropdown.open { display: block; }
  @keyframes dropDown {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .dropdown-header {
    padding: 1rem 1.2rem 0.75rem;
    border-bottom: 1px solid rgba(200,134,10,0.15);
  }
  .dropdown-name {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--brown);
  }
  .dropdown-email {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 2px;
  }
  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 1.2rem;
    font-size: 0.85rem;
    color: var(--brown);
    cursor: pointer;
    transition: background 0.15s;
    border: none;
    background: none;
    width: 100%;
    text-align: left;
    font-family: 'DM Sans', sans-serif;
  }
  .dropdown-item:hover { background: rgba(200,134,10,0.07); }
  .dropdown-item.danger { color: var(--deep-red); }
  .dropdown-item .di-icon { width: 16px; text-align: center; flex-shrink: 0; }

  /* ─── HERO ─── */
  .hero {
    min-height: 100vh;
    background: var(--bg-dark);
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 0%,rgba(200,134,10,0.25) 0%,transparent 60%),
      radial-gradient(ellipse 60% 40% at 80% 100%,rgba(224,92,26,0.2) 0%,transparent 60%);
  }
  .hero-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    background-image: repeating-linear-gradient(45deg,#C8860A 0px,#C8860A 1px,transparent 1px,transparent 30px),
      repeating-linear-gradient(-45deg,#C8860A 0px,#C8860A 1px,transparent 1px,transparent 30px);
  }
  .tagline-top {
    font-size: 0.75rem;
    letter-spacing: 0.35em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    position: relative;
    animation: fadeUp 0.8s ease both;
  }
  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3.5rem,10vw,7rem);
    font-weight: 900;
    line-height: 0.95;
    color: var(--cream);
    position: relative;
    animation: fadeUp 0.9s 0.15s ease both;
  }
  .hero-title span { color: var(--gold-light); font-style: italic; }
  .hero-sub {
    font-size: 1rem;
    color: rgba(253,246,236,0.6);
    margin-top: 1.5rem;
    font-weight: 300;
    letter-spacing: 0.05em;
    position: relative;
    animation: fadeUp 1s 0.3s ease both;
  }
  .hero-motto {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-style: italic;
    color: var(--gold-light);
    margin-top: 0.6rem;
    letter-spacing: 0.08em;
    position: relative;
    animation: fadeUp 1s 0.38s ease both;
  }
  .hero-divider {
    width: 60px;
    height: 2px;
    background: var(--gold);
    margin: 2rem auto;
    position: relative;
    animation: fadeUp 1s 0.4s ease both;
  }
  .hero-cta {
    display: inline-block;
    background: var(--gold);
    color: var(--bg-dark);
    font-weight: 500;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 1rem 2.5rem;
    text-decoration: none;
    border-radius: 2px;
    transition: background 0.2s, transform 0.2s;
    position: relative;
    animation: fadeUp 1s 0.5s ease both;
  }
  .hero-cta:hover { background: var(--gold-light); transform: translateY(-2px); }

  /* ─── ABOUT STRIP ─── */
  .about-strip {
    background: var(--deep-red);
    padding: 1.5rem 2rem;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .about-strip p { color: rgba(253,246,236,0.85); font-size: 0.85rem; letter-spacing: 0.08em; font-weight: 300; }
  .about-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--gold); flex-shrink: 0; }

  /* ─── HOURS ─── */
  .hours-section { background: var(--brown); padding: 3rem 2rem; text-align: center; }
  .hours-inner { max-width: 480px; margin: 0 auto; }
  .hours-section .section-label { color: var(--gold); }
  .hours-section .section-title { color: var(--cream); }
  .hours-grid { display: flex; flex-direction: column; gap: 0.6rem; margin-top: 2rem; }
  .hours-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.85rem 1.2rem;
    background: rgba(255,255,255,0.05);
    border-radius: 6px;
    border: 1px solid rgba(200,134,10,0.2);
  }
  .hours-row.highlight { border-color: var(--gold); background: rgba(200,134,10,0.1); }
  .hours-day { font-size: 0.85rem; color: rgba(253,246,236,0.7); font-weight: 400; letter-spacing: 0.05em; }
  .hours-time { font-family: 'Playfair Display', serif; font-size: 0.95rem; color: var(--gold-light); font-weight: 700; }

  /* ─── SECTION STYLES ─── */
  .section-label { font-size: 0.7rem; letter-spacing: 0.4em; text-transform: uppercase; color: var(--gold); font-weight: 500; margin-bottom: 0.75rem; text-align: center; }
  .section-title { font-family: 'Playfair Display', serif; font-size: clamp(2rem,5vw,3.2rem); font-weight: 700; text-align: center; color: var(--brown); margin-bottom: 0.5rem; }
  .section-title em { color: var(--deep-red); font-style: italic; }
  .section-divider { width: 50px; height: 2px; background: var(--gold); margin: 1.5rem auto 3.5rem; }

  /* ─── MENU ─── */
  .menu-section { max-width: 900px; margin: 0 auto; padding: 5rem 2rem; }
  .menu-category { margin-bottom: 3rem; }
  .cat-label {
    font-size: 0.65rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-weight: 500;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(200,134,10,0.2);
    margin-bottom: 1rem;
  }
  .menu-item {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: 1.1rem 1.4rem;
    margin-bottom: 0.6rem;
    border-radius: 6px;
    border: 1px solid rgba(200,134,10,0.12);
    background: #fff;
    cursor: pointer;
    transition: all 0.2s;
    gap: 1rem;
  }
  .menu-item:hover { border-color: var(--gold); background: #fffbf5; transform: translateX(4px); box-shadow: 3px 3px 12px rgba(200,134,10,0.1); }
  .menu-item.selected { border-color: var(--deep-red); background: #fff5f5; box-shadow: 0 0 0 2px rgba(139,26,26,0.15); }
  .item-left { display: flex; align-items: center; gap: 1rem; flex: 1; }
  .item-check {
    width: 22px; height: 22px;
    border-radius: 50%;
    border: 1.5px solid rgba(200,134,10,0.35);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: all 0.2s;
  }
  .menu-item.selected .item-check { background: var(--deep-red); border-color: var(--deep-red); }
  .item-check svg { display: none; }
  .menu-item.selected .item-check svg { display: block; }
  .item-info { flex: 1; }
  .item-name { font-size: 0.95rem; font-weight: 500; color: var(--brown); line-height: 1.4; }
  .item-price { font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 700; color: var(--deep-red); flex-shrink: 0; }
  .item-price span { font-size: 0.7rem; font-family: 'DM Sans', sans-serif; color: var(--text-muted); font-weight: 400; display: block; text-align: right; }
  .qty-wrap { display: none; align-items: center; gap: 8px; flex-shrink: 0; }
  .menu-item.selected .qty-wrap { display: flex; }
  .qty-btn { width: 26px; height: 26px; border-radius: 50%; border: 1.5px solid var(--deep-red); background: none; color: var(--deep-red); font-size: 1rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.15s; font-weight: 500; }
  .qty-btn:hover { background: var(--deep-red); color: #fff; }
  .qty-num { font-size: 0.9rem; font-weight: 500; min-width: 16px; text-align: center; color: var(--brown); }

  /* ─── ORDER BAR ─── */
  .order-summary {
    position: sticky;
    bottom: 0;
    background: var(--bg-dark);
    border-top: 2px solid var(--gold);
    padding: 1.25rem 2rem;
    display: none;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    z-index: 100;
    animation: slideUp 0.3s ease;
  }
  .order-summary.visible { display: flex; }
  .order-info { color: var(--cream); }
  .order-count { font-size: 0.75rem; letter-spacing: 0.1em; color: var(--gold); text-transform: uppercase; margin-bottom: 2px; }
  .order-total { font-family: 'Playfair Display', serif; font-size: 1.5rem; color: var(--cream); }
  .order-total small { font-family: 'DM Sans', sans-serif; font-size: 0.8rem; color: var(--text-muted); font-style: normal; }
  .whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: #25D366;
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 0.9rem;
    padding: 0.85rem 2rem;
    border-radius: 4px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
  }
  .whatsapp-btn:hover { background: #1ebe5a; transform: translateY(-1px); }
  .whatsapp-btn svg { width: 20px; height: 20px; fill: #fff; flex-shrink: 0; }

  /* ─── MODAL ─── */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(26,10,0,0.85);
    z-index: 999;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    animation: fadeIn 0.2s ease;
  }
  .modal-overlay.open { display: flex; }
  .modal-box {
    background: var(--cream);
    border-radius: 10px;
    padding: 2rem;
    max-width: 440px;
    width: 100%;
    position: relative;
    animation: slideUp 0.3s ease;
  }
  .modal-close { position: absolute; top: 1rem; right: 1rem; background: none; border: none; font-size: 1.4rem; color: var(--text-muted); cursor: pointer; line-height: 1; }
  .modal-close:hover { color: var(--deep-red); }
  .modal-title { font-family: 'Playfair Display', serif; font-size: 1.4rem; font-weight: 700; color: var(--brown); margin-bottom: 0.3rem; }
  .modal-sub { font-size: 0.82rem; color: var(--text-muted); margin-bottom: 1.5rem; }
  .field-group { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 1.5rem; }
  .field-label { font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); font-weight: 500; margin-bottom: 0.35rem; }
  .field-input { width: 100%; padding: 0.75rem 1rem; border: 1.5px solid rgba(200,134,10,0.25); border-radius: 6px; font-family: 'DM Sans', sans-serif; font-size: 0.95rem; color: var(--brown); background: #fff; outline: none; transition: border-color 0.2s; }
  .field-input:focus { border-color: var(--gold); }
  .field-input.error { border-color: var(--deep-red); }
  .field-error { font-size: 0.75rem; color: var(--deep-red); margin-top: 0.3rem; display: none; }
  .modal-confirm-btn {
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    background: #25D366;
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 0.95rem;
    padding: 0.95rem 2rem;
    border-radius: 6px;
    border: none;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
  }
  .modal-confirm-btn:hover { background: #1ebe5a; transform: translateY(-1px); }
  .modal-confirm-btn svg { width: 20px; height: 20px; fill: #fff; flex-shrink: 0; }
  .modal-order-preview { background: #fff; border-radius: 6px; padding: 0.9rem 1rem; border: 1px solid rgba(200,134,10,0.2); margin-bottom: 1.2rem; font-size: 0.82rem; color: var(--text-muted); max-height: 120px; overflow-y: auto; }
  .modal-order-preview p { margin-bottom: 0.3rem; line-height: 1.5; }
  .modal-order-preview .preview-total { font-family: 'Playfair Display', serif; font-size: 1rem; color: var(--deep-red); font-weight: 700; margin-top: 0.5rem; }

  /* ─── ORDER HISTORY MODAL ─── */
  .history-modal-box {
    background: var(--cream);
    border-radius: 14px;
    padding: 2rem;
    max-width: 520px;
    width: 100%;
    max-height: 80vh;
    overflow-y: auto;
    position: relative;
    animation: slideUp 0.3s ease;
  }
  .history-empty { text-align: center; padding: 2rem; color: var(--text-muted); font-style: italic; }
  .history-order-item {
    background: #fff;
    border-radius: 8px;
    border: 1px solid rgba(200,134,10,0.15);
    padding: 1rem 1.2rem;
    margin-bottom: 0.75rem;
  }
  .history-order-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; }
  .history-order-date { font-size: 0.75rem; color: var(--text-muted); }
  .history-order-total { font-family: 'Playfair Display', serif; font-size: 1rem; color: var(--deep-red); font-weight: 700; }
  .history-order-lines { font-size: 0.82rem; color: var(--text-muted); line-height: 1.7; }

  /* ─── FOOTER ─── */
  footer { background: var(--bg-dark); padding: 3rem 2rem; text-align: center; }
