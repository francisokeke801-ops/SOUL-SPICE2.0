      <p class="auth-title">Reset Password &#128273;</p>
      <p class="auth-sub">Enter your account email and we'll give you a reset code.</p>
      <div id="resetAlert" class="auth-alert"></div>
      <!-- Step 1 -->
      <div id="resetStep1">
        <div class="auth-field">
          <label>Email Address</label>
          <input type="email" id="resetEmail" placeholder="e.g. chukwu@email.com" autocomplete="email">
