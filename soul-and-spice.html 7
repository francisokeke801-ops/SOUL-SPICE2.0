<script>
  const PHONE = '2349123264034';
  const cart = {};

  // ─── STORAGE HELPERS ───
  function getUsers() { try { return JSON.parse(localStorage.getItem('ss_users') || '{}'); } catch(e) { return {}; } }
  function saveUsers(u) { localStorage.setItem('ss_users', JSON.stringify(u)); }
  function getCurrentUser() { try { return JSON.parse(localStorage.getItem('ss_current') || 'null'); } catch(e) { return null; } }
  function setCurrentUser(u) { localStorage.setItem('ss_current', JSON.stringify(u)); }
  function clearCurrentUser() { localStorage.removeItem('ss_current'); }

  function getUserOrders(email) {
    try { return JSON.parse(localStorage.getItem('ss_orders_' + email) || '[]'); } catch(e) { return []; }
  }
  function saveUserOrder(email, order) {
    const orders = getUserOrders(email);
    orders.unshift(order);
    localStorage.setItem('ss_orders_' + email, JSON.stringify(orders));
  }

  // ─── AUTH TABS ───
  function switchAuthTab(tab) {
    document.querySelectorAll('.auth-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.auth-panel').forEach(p => p.classList.remove('active'));
    if (tab === 'login') {
      document.querySelector('.auth-tab:nth-child(1)').classList.add('active');
      document.getElementById('loginPanel').classList.add('active');
    } else if (tab === 'signup') {
      document.querySelector('.auth-tab:nth-child(2)').classList.add('active');
      document.getElementById('signupPanel').classList.add('active');
    } else if (tab === 'reset') {
      // No tab highlighted for reset — it's a sub-flow of login
      document.getElementById('resetPanel').classList.add('active');
      // Reset state
      document.getElementById('resetStep1').style.display = 'block';
      document.getElementById('resetStep2').style.display = 'none';
      document.getElementById('resetEmail').value = '';
      document.getElementById('resetCodeInput').value = '';
      document.getElementById('resetNewPass').value = '';
      document.getElementById('resetConfirmPass').value = '';
      document.getElementById('resetAlert').className = 'auth-alert';
      ['resetEmailErr','resetCodeErr','resetNewPassErr','resetConfirmPassErr'].forEach(id => {
        document.getElementById(id).classList.remove('show');
        const inp = document.getElementById(id.replace('Err','').replace('reset','reset'));
        if (inp) inp.classList.remove('error');
      });
    }
  }

  // ─── RESET PASSWORD ───
  let _resetCode = '';
  let _resetEmail = '';

  function doSendResetCode() {
    const email = document.getElementById('resetEmail').value.trim().toLowerCase();
    const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    document.getElementById('resetEmail').classList.toggle('error', !emailOk);
    document.getElementById('resetEmailErr').classList.toggle('show', !emailOk);
    if (!emailOk) return;

    const users = getUsers();
    const alertEl = document.getElementById('resetAlert');
    alertEl.className = 'auth-alert';

    if (!users[email]) {
      alertEl.textContent = 'No account found with that email address.';
      alertEl.className = 'auth-alert error';
      return;
    }

    // Generate a 6-digit code
    _resetCode  = String(Math.floor(100000 + Math.random() * 900000));
    _resetEmail = email;

    document.getElementById('resetCodeValue').textContent = _resetCode;
    document.getElementById('resetStep1').style.display = 'none';
    document.getElementById('resetStep2').style.display = 'block';
  }

  function doResetPassword() {
    const code    = document.getElementById('resetCodeInput').value.trim();
    const newPass = document.getElementById('resetNewPass').value;
    const confirm = document.getElementById('resetConfirmPass').value;
    let valid = true;

    const codeOk = code === _resetCode;
    document.getElementById('resetCodeInput').classList.toggle('error', !codeOk);
    document.getElementById('resetCodeErr').classList.toggle('show', !codeOk);
    if (!codeOk) valid = false;

    const passOk = newPass.length >= 6;
    document.getElementById('resetNewPass').classList.toggle('error', !passOk);
    document.getElementById('resetNewPassErr').classList.toggle('show', !passOk);
    if (!passOk) valid = false;

    const matchOk = newPass === confirm;
    document.getElementById('resetConfirmPass').classList.toggle('error', !matchOk);
    document.getElementById('resetConfirmPassErr').classList.toggle('show', !matchOk);
    if (!matchOk) valid = false;

    if (!valid) return;

    // Update password in storage
    const users = getUsers();
    if (users[_resetEmail]) {
      users[_resetEmail].password = btoa(newPass);
      saveUsers(users);
    }

    const alertEl = document.getElementById('resetAlert');
    alertEl.textContent = '✓ Password updated! You can now sign in.';
    alertEl.className = 'auth-alert success';

    // Clear state
    _resetCode = '';
    _resetEmail = '';

    setTimeout(() => switchAuthTab('login'), 1800);
  }

  // ─── SIGNUP ───
  function doSignup() {
    const name    = document.getElementById('signupName').value.trim();
    const phone   = document.getElementById('signupPhone').value.trim();
    const email   = document.getElementById('signupEmail').value.trim().toLowerCase();
    const pass    = document.getElementById('signupPassword').value;
    const address = document.getElementById('signupAddress').value.trim();
    let valid = true;

    const fields = [
      ['signupName',    'signupNameErr',  name,  n => n.length >= 2],
      ['signupPhone',   'signupPhoneErr', phone, p => p.length >= 7],
      ['signupEmail',   'signupEmailErr', email, e => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e)],
      ['signupPassword','signupPassErr',  pass,  p => p.length >= 6],
      ['signupAddress', 'signupAddrErr',  address, a => a.length >= 3],
    ];
    fields.forEach(([id, errId, val, test]) => {
      const ok = test(val);
      document.getElementById(id).classList.toggle('error', !ok);
      document.getElementById(errId).classList.toggle('show', !ok);
      if (!ok) valid = false;
    });

    const alertEl = document.getElementById('signupAlert');
    alertEl.className = 'auth-alert';

    if (!valid) return;

    const users = getUsers();
    if (users[email]) {
      alertEl.textContent = 'An account with this email already exists. Please sign in.';
      alertEl.className = 'auth-alert error';
      return;
    }

    users[email] = { name, phone, email, password: btoa(pass), address, createdAt: Date.now() };
    saveUsers(users);
    setCurrentUser({ name, phone, email, address });
    onLogin();
  }

  // ─── LOGIN ───
  function doLogin() {
    const email = document.getElementById('loginEmail').value.trim().toLowerCase();
    const pass  = document.getElementById('loginPassword').value;
    let valid = true;

    const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    document.getElementById('loginEmail').classList.toggle('error', !emailOk);
    document.getElementById('loginEmailErr').classList.toggle('show', !emailOk);
    if (!emailOk) valid = false;

    const passOk = pass.length > 0;
    document.getElementById('loginPassword').classList.toggle('error', !passOk);
    document.getElementById('loginPassErr').classList.toggle('show', !passOk);
    if (!passOk) valid = false;

    const alertEl = document.getElementById('loginAlert');
    alertEl.className = 'auth-alert';

    if (!valid) return;

    const users = getUsers();
    const user = users[email];
    if (!user || user.password !== btoa(pass)) {
      alertEl.textContent = 'Incorrect email or password. Please try again.';
      alertEl.className = 'auth-alert error';
      return;
    }

    setCurrentUser({ name: user.name, phone: user.phone, email: user.email, address: user.address });
    onLogin();
  }

  // ─── ON LOGIN ───
  function onLogin() {
    const user = getCurrentUser();
    if (!user) return;

    document.getElementById('authGate').classList.remove('show');
    document.getElementById('navbar').style.display = 'flex';
    document.getElementById('welcomeBanner').classList.add('show');
    document.getElementById('welcomeName').textContent = user.name.split(' ')[0];

    document.getElementById('navAvatar').textContent = user.name.charAt(0).toUpperCase();
    document.getElementById('navUserName').textContent = user.name.split(' ')[0];
    document.getElementById('dropdownName').textContent = user.name;
    document.getElementById('dropdownEmail').textContent = user.email;

    // Pre-fill modal fields
    document.getElementById('custName').value    = user.name;
    document.getElementById('custPhone').value   = user.phone || '';
    document.getElementById('custAddress').value = user.address || '';

    // Add navbar padding to body
    document.body.style.paddingTop = '64px';

    setTimeout(() => {
      document.getElementById('welcomeBanner').classList.remove('show');
    }, 4000);
  }

  // ─── LOGOUT ───
  function doLogout() {
    clearCurrentUser();
    document.getElementById('navbar').style.display = 'none';
    document.getElementById('navDropdown').classList.remove('open');
    document.getElementById('authGate').classList.add('show');
    document.getElementById('welcomeBanner').classList.remove('show');
    document.body.style.paddingTop = '0';
    document.getElementById('loginEmail').value = '';
    document.getElementById('loginPassword').value = '';
    document.getElementById('loginAlert').className = 'auth-alert';
    switchAuthTab('login');
  }

  // ─── DROPDOWN ───
  function toggleDropdown() {
    document.getElementById('navDropdown').classList.toggle('open');
  }
  document.addEventListener('click', e => {
    const btn = document.getElementById('navUserBtn');
    const dd = document.getElementById('navDropdown');
    if (!btn.contains(e.target) && !dd.contains(e.target)) dd.classList.remove('open');
  });

  // ─── ORDER HISTORY ───
  function openOrderHistory() {
    document.getElementById('navDropdown').classList.remove('open');
    const user = getCurrentUser();
    if (!user) return;
    const orders = getUserOrders(user.email);
    const container = document.getElementById('historyContent');
    if (orders.length === 0) {
      container.innerHTML = '<div class="history-empty">No orders yet. Start browsing the menu! 🍛</div>';
    } else {
      container.innerHTML = orders.map(o => `
        <div class="history-order-item">
          <div class="history-order-meta">
            <span class="history-order-date">${new Date(o.date).toLocaleDateString('en-NG', {day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'})}</span>
            <span class="history-order-total">₦${o.total.toLocaleString()}</span>
          </div>
          <div class="history-order-lines">${o.items.map(i => `• ${i.name} ×${i.qty}`).join('<br>')}</div>
          <div style="font-size:0.75rem;color:var(--text-muted);margin-top:0.4rem;">📍 ${o.address}</div>
        </div>
      `).join('');
    }
    document.getElementById('historyModal').classList.add('open');
  }
  function closeHistoryModal() { document.getElementById('historyModal').classList.remove('open'); }

  // ─── PROFILE EDIT ───
  function openProfileEdit() {
    document.getElementById('navDropdown').classList.remove('open');
    const user = getCurrentUser();
    if (!user) return;
    document.getElementById('editName').value    = user.name;
    document.getElementById('editPhone').value   = user.phone || '';
    document.getElementById('editAddress').value = user.address || '';
    document.getElementById('profileAlert').className = 'auth-alert';
    document.getElementById('profileModal').classList.add('open');
  }
  function closeProfileModal() { document.getElementById('profileModal').classList.remove('open'); }
  function saveProfile() {
    const user = getCurrentUser();
    if (!user) return;
    const name    = document.getElementById('editName').value.trim();
    const phone   = document.getElementById('editPhone').value.trim();
    const address = document.getElementById('editAddress').value.trim();
    if (!name) {
      const a = document.getElementById('profileAlert');
      a.textContent = 'Name cannot be empty.';
      a.className = 'auth-alert error';
      return;
    }
    const updated = { ...user, name, phone, address };
    setCurrentUser(updated);
    // Update users store
    const users = getUsers();
    if (users[user.email]) {
      users[user.email] = { ...users[user.email], name, phone, address };
      saveUsers(users);
    }
    document.getElementById('navAvatar').textContent  = name.charAt(0).toUpperCase();
    document.getElementById('navUserName').textContent = name.split(' ')[0];
    document.getElementById('dropdownName').textContent = name;
    document.getElementById('custName').value    = name;
    document.getElementById('custPhone').value   = phone;
    document.getElementById('custAddress').value = address;

    const a = document.getElementById('profileAlert');
    a.textContent = '✓ Profile updated successfully!';
    a.className = 'auth-alert success';
    setTimeout(closeProfileModal, 1200);
  }

  // ─── CART ───
  const orderBar   = document.getElementById('orderBar');
  const orderCount = document.getElementById('orderCount');
  const orderTotal = document.getElementById('orderTotal');
  const modal      = document.getElementById('orderModal');

  function updateBar() {
    const items = Object.values(cart);
    const total = items.reduce((s, i) => s + i.price * i.qty, 0);
    const count = items.reduce((s, i) => s + i.qty, 0);
    if (count === 0) { orderBar.classList.remove('visible'); }
    else {
      orderBar.classList.add('visible');
      orderCount.textContent = count + (count === 1 ? ' item selected' : ' items selected');
      orderTotal.textContent = total.toLocaleString();
    }
  }

  function openOrderModal() {
    const items = Object.values(cart);
    if (items.length === 0) return;
    const total = items.reduce((s, i) => s + i.price * i.qty, 0);
    const preview = document.getElementById('orderPreview');
    preview.innerHTML = items.map(i => `<p>• ${i.name} ×${i.qty} — ₦${(i.price * i.qty).toLocaleString()}</p>`).join('') + `<p class="preview-total">Total: ₦${total.toLocaleString()}</p>`;
    modal.classList.add('open');
  }

  function closeOrderModal() {
    modal.classList.remove('open');
    ['nameErr','phoneErr','addressErr'].forEach(id => document.getElementById(id).style.display = 'none');
    ['custName','custPhone','custAddress'].forEach(id => document.getElementById(id).classList.remove('error'));
  }
  modal.addEventListener('click', e => { if (e.target === modal) closeOrderModal(); });

  function confirmOrder() {
    const name    = document.getElementById('custName').value.trim();
    const phone   = document.getElementById('custPhone').value.trim();
    const address = document.getElementById('custAddress').value.trim();
    let valid = true;

    if (!name) { document.getElementById('nameErr').style.display='block'; document.getElementById('custName').classList.add('error'); valid=false; }
    else { document.getElementById('nameErr').style.display='none'; document.getElementById('custName').classList.remove('error'); }
    if (!phone || phone.length < 7) { document.getElementById('phoneErr').style.display='block'; document.getElementById('custPhone').classList.add('error'); valid=false; }
    else { document.getElementById('phoneErr').style.display='none'; document.getElementById('custPhone').classList.remove('error'); }
    if (!address) { document.getElementById('addressErr').style.display='block'; document.getElementById('custAddress').classList.add('error'); valid=false; }
    else { document.getElementById('addressErr').style.display='none'; document.getElementById('custAddress').classList.remove('error'); }

    if (!valid) return;

    const items = Object.values(cart);
    const total = items.reduce((s, i) => s + i.price * i.qty, 0);
    const lines = items.map(i => `• ${i.name} x${i.qty} = ₦${(i.price * i.qty).toLocaleString()}`);

    // Save order to history
    const user = getCurrentUser();
    if (user) {
      saveUserOrder(user.email, {
        date: Date.now(),
        items: items.map(i => ({ name: i.name, qty: i.qty, price: i.price })),
        total,
        address,
        name,
        phone
      });
    }

    const msg =
`Hello Soul & Spice! 👋

I'd like to place an order:

${lines.join('\n')}

*Total: ₦${total.toLocaleString()}*

---
👤 Name: ${name}
📞 Phone: ${phone}
📍 Address: ${address}

Please confirm availability. Thank you!`;

    window.open(`https://wa.me/${PHONE}?text=${encodeURIComponent(msg)}`, '_blank');
    closeOrderModal();
  }

  document.querySelectorAll('.menu-item').forEach(item => {
    const id    = item.dataset.id;
    const name  = item.dataset.name;
    const price = parseInt(item.dataset.price);
    const qtyEl = item.querySelector('.qty-num');
    const minus = item.querySelector('.qty-btn.minus');
    const plus  = item.querySelector('.qty-btn.plus');

    item.addEventListener('click', e => {
      if (e.target.closest('.qty-btn')) return;
      if (item.classList.contains('selected')) {
        item.classList.remove('selected');
        delete cart[id];
      } else {
        item.classList.add('selected');
        cart[id] = { name, price, qty: 1 };
        qtyEl.textContent = '1';
      }
      updateBar();
    });

    minus.addEventListener('click', e => {
      e.stopPropagation();
      const q = parseInt(qtyEl.textContent);
      if (q <= 1) { item.classList.remove('selected'); delete cart[id]; }
      else { cart[id].qty = q - 1; qtyEl.textContent = q - 1; }
      updateBar();
    });

    plus.addEventListener('click', e => {
      e.stopPropagation();
      const q = parseInt(qtyEl.textContent);
      if (!cart[id]) { cart[id] = { name, price, qty: 1 }; item.classList.add('selected'); }
      cart[id].qty = q + 1;
      qtyEl.textContent = q + 1;
      updateBar();
    });
  });

  // Close history/profile modals on overlay click
  document.getElementById('historyModal').addEventListener('click', e => { if (e.target === document.getElementById('historyModal')) closeHistoryModal(); });
  document.getElementById('profileModal').addEventListener('click', e => { if (e.target === document.getElementById('profileModal')) closeProfileModal(); });

  // Keyboard enter support on login/signup
  document.getElementById('loginPassword').addEventListener('keydown', e => { if (e.key === 'Enter') doLogin(); });
  document.getElementById('signupAddress').addEventListener('keydown', e => { if (e.key === 'Enter') doSignup(); });

  // ─── AUTO-LOGIN CHECK ───
  (function() {
    const user = getCurrentUser();
    if (user) onLogin();
  })();
</script>
</body>
</html>
